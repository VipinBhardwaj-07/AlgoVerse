{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/chat",
      "dest": "api/index.js"
    },
    {
      "src": "/api/chat",
      "dest": "api/index.js"
    },
    {
      "src": "/create-checkout-session",
      "dest": "api/index.js"
    },
    {
      "src": "/api/create-checkout-session",
      "dest": "api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}