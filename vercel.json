{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/chat",
      "dest": "api/index.js"
    },
    {
      "src": "/api/chat",
      "dest": "api/index.js"
    },
    {
      "src": "/create-checkout-session",
      "dest": "api/index.js"
    },
    {
      "src": "/api/create-checkout-session",
      "dest": "api/index.js"
    },
    {
      "handle": "filesystem"
    }
  ]
}